<div class="module image-band">

    <div class="row no-gutters">

        {% for image in module.image_band %}
        <div class="col-md image-band-image-{{loop.index}}">
            {% if image.image %}<img src="{{TimberImage(image.image).src|resize(4000,2000)}}">{% endif %}
        </div>
        {% endfor %}

     </div>

</div>